# Copiar a .env y completar credenciales reales.

# Django
DJANGO_SECRET_KEY=change-me
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,bonanza.robio-ai.com
CSRF_TRUSTED_ORIGINS=https://localhost,https://127.0.0.1,https://bonanza.robio-ai.com

# Base de datos principal
DATABASE_ENGINE=django.db.backends.sqlite3
DATABASE_NAME=/home/yandriuchuari/server/DashboardBZA/inventario_bonanza/db.sqlite3
DATABASE_ADMIN_USER=robiotec
DATABASE_ADMIN_PASSWORD=change-me
DATABASE_DESCRIPTION=SQLite local actual. Si se migra a PostgreSQL, actualizar variables de conexion.

# Administrador global
GLOBAL_ADMIN_USERNAME=robiotec
GLOBAL_ADMIN_PASSWORD=change-me
GLOBAL_ADMIN_EMAIL=robiotec@example.com

# MinIO / S3
MINIO_ROOT_USER=robiotec
MINIO_ROOT_PASSWORD=change-me
MINIO_ACCESS_KEY=robiotec
MINIO_SECRET_KEY=change-me
MINIO_BUCKET_NAME=dashboard-personal
MINIO_ENDPOINT_URL=http://127.0.0.1:9000
MINIO_CONSOLE_URL=http://127.0.0.1:9001
MINIO_VOLUMES=/home/yandriuchuari/server/DashboardBZA/MinIO
MINIO_OPTS=--address 127.0.0.1:9000 --console-address 127.0.0.1:9001
MINIO_PERSON_PHOTO_PATH=personas/<cedula>.png

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=

# Correo
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Servicios locales
DJANGO_SERVICE=inventario_bonanza.service
MINIO_SERVICE=minio.service
NGINX_SITE=/etc/nginx/sites-available/inventario_bonanza
APP_URL=https://bonanza.robio-ai.com
